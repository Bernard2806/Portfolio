---
import "../styles/global.css";
import BackgroundAnimation from "../components/BackgroundAnimation.astro";

interface Props {
  title: string;
  description?: string;
}

const { 
  title, 
  description = "Perfil profesional de Bernardo González - Desarrollador Web especializado en .NET, PHP, C# y bases de datos SQL." 
} = Astro.props;
---

<!DOCTYPE html>
<html lang="es" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    
    <!-- SEO Meta Tags -->
    <meta name="description" content={description} />
    <meta name="author" content="Bernardo González" />
    <meta name="robots" content="index, follow" />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="https://github.com/Bernard2806.png" />
    <meta property="og:url" content="https://bernard2806.is-a.dev" />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content="https://github.com/Bernard2806.png" />

    <!-- Icon -->
    <link rel="icon" href="https://github.com/Bernard2806.png" type="image/png" />
    
    <!-- FontAwesome Icons -->
    <link
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
      rel="stylesheet"
      crossorigin="anonymous"
    />

  </head>
  <body>
    <BackgroundAnimation />
    <slot />
  </body>
</html>

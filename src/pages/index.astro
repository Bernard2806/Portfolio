---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Experience from "../components/Experience.astro";
import Education from "../components/Education.astro";
import Socials from "../components/Socials.astro";
import Ventures from "../components/Ventures.astro";
import Projects from "../components/Projects.astro";
import Products from "../components/Products.astro";
import Contact from "../components/Contact.astro";
import ProjectModals from "../components/ProjectModals.astro";
import portfolioData from "../data/portfolio.json";

const { name, lastName, title } = portfolioData.personalInfo;
const currentYear = new Date().getFullYear();
---

<Layout title={`${name} ${lastName} | ${title}`}>
  <div class="hub-wrapper">
    <!-- Main Interactive Card -->
    <main class="hub-card">
      <!-- Profile Cover Banner + Avatar Info + Linktree Buttons Stack -->
      <Hero />
      
      <!-- Accordion Navigation Stack -->
      <div class="linktree-menu">
        <!-- Item: Sobre Mí -->
        <div class="accordion-item">
          <button class="linktree-btn active" data-tab="about">
            <span class="btn-icon"><i class="fas fa-user-tie"></i></span>
            <span class="btn-text">Sobre Mí</span>
            <span class="btn-chevron"><i class="fas fa-chevron-right"></i></span>
          </button>
          <div class="accordion-content active" id="panel-about">
            <div class="accordion-content-inner">
              <About />
            </div>
          </div>
        </div>

        <!-- Item: Experiencia Laboral -->
        <div class="accordion-item">
          <button class="linktree-btn" data-tab="experience">
            <span class="btn-icon"><i class="fas fa-briefcase"></i></span>
            <span class="btn-text">Experiencia Laboral</span>
            <span class="btn-chevron"><i class="fas fa-chevron-right"></i></span>
          </button>
          <div class="accordion-content" id="panel-experience">
            <div class="accordion-content-inner">
              <Experience />
            </div>
          </div>
        </div>

        <!-- Item: Estudios -->
        <div class="accordion-item">
          <button class="linktree-btn" data-tab="education">
            <span class="btn-icon"><i class="fas fa-graduation-cap"></i></span>
            <span class="btn-text">Estudios</span>
            <span class="btn-chevron"><i class="fas fa-chevron-right"></i></span>
          </button>
          <div class="accordion-content" id="panel-education">
            <div class="accordion-content-inner">
              <Education />
            </div>
          </div>
        </div>

        <!-- Item: Redes Sociales -->
        <div class="accordion-item">
          <button class="linktree-btn" data-tab="socials">
            <span class="btn-icon"><i class="fas fa-share-nodes"></i></span>
            <span class="btn-text">Redes Sociales</span>
            <span class="btn-chevron"><i class="fas fa-chevron-right"></i></span>
          </button>
          <div class="accordion-content" id="panel-socials">
            <div class="accordion-content-inner">
              <Socials />
            </div>
          </div>
        </div>

        <!-- Item: Emprendimientos -->
        <div class="accordion-item">
          <button class="linktree-btn" data-tab="ventures">
            <span class="btn-icon"><i class="fas fa-rocket"></i></span>
            <span class="btn-text">Emprendimientos</span>
            <span class="btn-chevron"><i class="fas fa-chevron-right"></i></span>
          </button>
          <div class="accordion-content" id="panel-ventures">
            <div class="accordion-content-inner">
              <Ventures />
            </div>
          </div>
        </div>

        <!-- Item: Proyectos de Desarrollo -->
        <div class="accordion-item">
          <button class="linktree-btn" data-tab="projects">
            <span class="btn-icon"><i class="fas fa-briefcase"></i></span>
            <span class="btn-text">Proyectos de Desarrollo</span>
            <span class="btn-chevron"><i class="fas fa-chevron-right"></i></span>
          </button>
          <div class="accordion-content" id="panel-projects">
            <div class="accordion-content-inner">
              <Projects />
            </div>
          </div>
        </div>

        <!-- Item: Software & SaaS en Venta -->
        <div class="accordion-item">
          <button class="linktree-btn" data-tab="products">
            <span class="btn-icon"><i class="fas fa-shopping-bag"></i></span>
            <span class="btn-text">Software & SaaS en Venta</span>
            <span class="btn-chevron"><i class="fas fa-chevron-right"></i></span>
          </button>
          <div class="accordion-content" id="panel-products">
            <div class="accordion-content-inner">
              <Products />
            </div>
          </div>
        </div>

        <!-- Item: Enviar Mensaje -->
        <div class="accordion-item">
          <button class="linktree-btn" data-tab="contact">
            <span class="btn-icon"><i class="fas fa-envelope"></i></span>
            <span class="btn-text">Enviar Mensaje</span>
            <span class="btn-chevron"><i class="fas fa-chevron-right"></i></span>
          </button>
          <div class="accordion-content" id="panel-contact">
            <div class="accordion-content-inner">
              <Contact />
            </div>
          </div>
        </div>
      </div>
    </main>

    <!-- Footer centered below the card -->
    <footer class="hub-footer">
      <p class="footer-copy">&copy; {currentYear} {name} {lastName}. Todos los derechos reservados.</p>
    </footer>
  </div>

  <!-- Floating Share Button (FAB) -->
  <button id="btn-open-share-modal" class="fab-share" aria-label="Compartir Perfil">
    <i class="fas fa-share-nodes"></i>
  </button>

  <!-- Modal: Compartir Perfil -->
  <div class="modal-overlay" id="modal-share">
    <div class="modal-share-container">
      <button class="modal-close-btn share-close-pos" data-close-target="modal-share" aria-label="Cerrar">
        <i class="fas fa-times"></i>
      </button>
      
      <h3 class="modal-share-title">Compartir Perfil</h3>
      
      <div class="qr-container-minimal">
        <img 
          src="https://api.qrserver.com/v1/create-qr-code/?size=150x150&data=https://bernard2806.is-a.dev" 
          alt="Código QR del Perfil" 
          class="qr-image-minimal"
          loading="lazy"
        />
      </div>
      
      <p class="qr-subtitle-minimal">Escaneá para abrir en tu celular</p>
    </div>
  </div>
  
  <ProjectModals />
</Layout>

<style>
  /* Footer styles centered below the card */
  .hub-footer {
    margin-top: 2rem;
    text-align: center;
    width: 100%;
  }

  .footer-copy {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  /* Floating Share Button (FAB) */
  .fab-share {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background-color: var(--accent-blue);
    color: #ffffff;
    border: none;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.35rem;
    cursor: pointer;
    box-shadow: 0 4px 16px rgba(34, 197, 94, 0.4);
    z-index: 900;
    transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .fab-share:hover {
    transform: scale(1.1) rotate(-8deg);
    box-shadow: 0 6px 20px rgba(34, 197, 94, 0.6);
    background-color: var(--accent-teal);
  }

  .fab-share:active {
    transform: scale(0.95);
  }

  @media (max-width: 576px) {
    .fab-share {
      bottom: 1.5rem;
      right: 1.5rem;
      width: 48px;
      height: 48px;
      font-size: 1.15rem;
    }
  }

  /* Glassmorphism modal specifically for Share */
  .modal-share-container {
    background: rgba(18, 27, 22, 0.65); /* Semi-transparent background matching card */
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(34, 197, 94, 0.15); /* Subtle green border */
    border-radius: 20px;
    width: 100%;
    max-width: 280px; /* Compact focused size for the QR card */
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5), 0 0 30px rgba(34, 197, 94, 0.05);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transform: scale(0.9) translateY(15px);
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    align-items: center;
    padding: 1.5rem;
    position: relative;
  }

  .modal-overlay.open .modal-share-container {
    transform: scale(1) translateY(0);
  }

  .share-close-pos {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    color: var(--text-muted);
  }

  .modal-share-title {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 1.25rem;
    text-align: center;
  }

  .qr-container-minimal {
    background-color: #ffffff; /* Contrast for scanning */
    padding: 0.85rem;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.2);
    margin-bottom: 1rem;
    transition: transform 0.3s ease;
  }

  .qr-container-minimal:hover {
    transform: scale(1.03);
  }

  .qr-image-minimal {
    width: 150px;
    height: 150px;
    display: block;
  }

  .qr-subtitle-minimal {
    font-size: 0.78rem;
    color: var(--text-secondary);
    text-align: center;
    line-height: 1.4;
  }
</style>

<script>
  const setupTabNavigation = () => {
    const buttons = document.querySelectorAll('.linktree-btn');

    buttons.forEach(button => {
      button.addEventListener('click', () => {
        const targetTab = button.getAttribute('data-tab');
        const targetPanel = document.getElementById(`panel-${targetTab}`);
        
        if (!targetPanel) return;

        const isCurrentlyActive = button.classList.contains('active');

        // Collapse all active panels first
        buttons.forEach(btn => {
          if (btn !== button) {
            btn.classList.remove('active');
            const pTab = btn.getAttribute('data-tab');
            const panel = document.getElementById(`panel-${pTab}`);
            if (panel) {
              panel.classList.remove('active');
            }
          }
        });

        // Toggle the clicked one
        if (isCurrentlyActive) {
          button.classList.remove('active');
          targetPanel.classList.remove('active');
        } else {
          button.classList.add('active');
          targetPanel.classList.add('active');

          // Smooth scroll to the clicked accordion item to focus attention
          setTimeout(() => {
            button.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
          }, 150);
        }
      });
    });
  };

  const setupShareModal = () => {
    const openBtn = document.getElementById('btn-open-share-modal');
    const modalShare = document.getElementById('modal-share');
    const closeBtns = document.querySelectorAll('#modal-share .modal-close-btn');

    if (openBtn && modalShare) {
      openBtn.addEventListener('click', async () => {
        // Detect if touch mobile device and Web Share API is available
        const isMobile = /Android|webOS|iPhone|iPad|iPod|BlackBerry|IEMobile|Opera Mini/i.test(navigator.userAgent);
        
        if (isMobile && navigator.share) {
          try {
            await navigator.share({
              title: 'Bernardo Andrés González Erramuspe | Desarrollador Web',
              text: 'Perfil profesional de Bernardo Andrés González Erramuspe - Desarrollador Web.',
              url: 'https://bernard2806.is-a.dev'
            });
          } catch (err) {
            // Fallback to modal if native share fails but not explicitly cancelled by user
            if (err.name !== 'AbortError') {
              modalShare.classList.add('open');
              document.body.style.overflow = 'hidden';
            }
          }
        } else {
          modalShare.classList.add('open');
          document.body.style.overflow = 'hidden';
        }
      });

      const close = () => {
        modalShare.classList.remove('open');
        document.body.style.overflow = '';
      };

      closeBtns.forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          close();
        });
      });

      modalShare.addEventListener('click', (e) => {
        if (e.target === modalShare) {
          close();
        }
      });
    }
  };

  // Run on initial page load
  setupTabNavigation();
  setupShareModal();
  // Run on Astro page transition swaps
  document.addEventListener('astro:after-swap', () => {
    setupTabNavigation();
    setupShareModal();
  });
</script>

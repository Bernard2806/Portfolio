---
import portfolioData from "../data/portfolio.json";

const { github, linkedin, instagram, facebook, steam, xbox } = portfolioData.personalInfo;

const socialLinks = [
  { name: "GitHub", url: github, icon: "fab fa-github" },
  { name: "LinkedIn", url: linkedin, icon: "fab fa-linkedin-in" },
  { name: "Instagram", url: instagram, icon: "fab fa-instagram" },
  { name: "Facebook", url: facebook, icon: "fab fa-facebook-f" }
];
---

<div class="panel-socials">
  <!-- Redes Principales -->
  <div class="socials-grid">
    {socialLinks.map((social) => (
      <a href={social.url} target="_blank" rel="noopener noreferrer" class="social-card">
        <div class="social-card-icon">
          <i class={social.icon}></i>
        </div>
        <span class="social-card-name">{social.name}</span>
      </a>
    ))}
  </div>

  <!-- Separador y Título de Streaming -->
  <div class="streaming-divider">
    <span class="divider-line"></span>
    <h4 class="streaming-title">Creador de contenido (ocasional)</h4>
    <span class="divider-line"></span>
  </div>

  <!-- Redes de Streaming -->
  <div class="socials-grid">
    <!-- Kick -->
    <a href="https://kick.com/bernardtw2806" target="_blank" rel="noopener noreferrer" class="social-card kick-card">
      <div class="social-card-icon kick-icon-container">
        <svg viewBox="0 0 512 512" fill="currentColor" class="kick-svg">
          <path d="M37 .036h164.448v113.621h54.71v-56.82h54.731V.036h164.448v170.777h-54.73v56.82h-54.711v56.8h54.71v56.82h54.73V512.03H310.89v-56.82h-54.73v-56.8h-54.711v113.62H37V.036z"/>
        </svg>
      </div>
      <span class="social-card-name">Kick</span>
    </a>

    <!-- Twitch -->
    <a href="https://www.twitch.tv/bernardtw2806" target="_blank" rel="noopener noreferrer" class="social-card twitch-card">
      <div class="social-card-icon twitch-icon-container">
        <i class="fab fa-twitch"></i>
      </div>
      <span class="social-card-name">Twitch</span>
    </a>
  </div>

  <!-- Separador y Título de Gaming -->
  <div class="streaming-divider">
    <span class="divider-line"></span>
    <h4 class="streaming-title">Gaming</h4>
    <span class="divider-line"></span>
  </div>

  <!-- Redes de Gaming -->
  <div class="socials-grid">
    <!-- Steam -->
    <a href={steam} target="_blank" rel="noopener noreferrer" class="social-card steam-card">
      <div class="social-card-icon steam-icon-container">
        <i class="fab fa-steam"></i>
      </div>
      <span class="social-card-name">Steam</span>
    </a>

    <!-- Xbox -->
    <a href={xbox} target="_blank" rel="noopener noreferrer" class="social-card xbox-card">
      <div class="social-card-icon xbox-icon-container">
        <i class="fab fa-xbox"></i>
      </div>
      <span class="social-card-name">Xbox</span>
    </a>
  </div>
</div>

<style>
  .panel-socials {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .socials-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1rem;
    width: 100%;
  }

  .social-card {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    text-decoration: none;
    transition: all var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
  }

  .social-card-icon {
    font-size: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 56px;
    width: 56px;
    border-radius: 50%;
    background-color: var(--bg-body);
    border: 1px solid var(--border-color);
    transition: all var(--transition-speed) ease;
    color: var(--text-secondary);
  }

  .social-card-name {
    font-family: var(--font-heading);
    font-weight: 700;
    font-size: 0.95rem;
    color: var(--text-primary);
  }

  /* Custom Hover Effects matching page palette */
  .social-card:hover {
    background-color: var(--bg-hover);
    transform: translateY(-3px);
  }

  .social-card:hover .social-card-icon {
    background-color: var(--bg-card);
    transform: scale(1.05);
  }

  /* GitHub Hover */
  .social-card:nth-child(1):hover {
    border-color: rgba(255, 255, 255, 0.3);
    box-shadow: 0 10px 15px -3px rgba(255, 255, 255, 0.05);
  }
  .social-card:nth-child(1):hover .social-card-icon {
    border-color: #ffffff;
    color: #ffffff;
    box-shadow: 0 0 12px rgba(255, 255, 255, 0.15);
  }

  /* LinkedIn Hover */
  .social-card:nth-child(2):hover {
    border-color: rgba(10, 102, 194, 0.3);
    box-shadow: 0 10px 15px -3px rgba(10, 102, 194, 0.08);
  }
  .social-card:nth-child(2):hover .social-card-icon {
    border-color: #0a66c2;
    color: #0a66c2;
    box-shadow: 0 0 12px rgba(10, 102, 194, 0.2);
  }

  /* Instagram Hover */
  .social-card:nth-child(3):hover {
    border-color: rgba(225, 48, 108, 0.3);
    box-shadow: 0 10px 15px -3px rgba(225, 48, 108, 0.08);
  }
  .social-card:nth-child(3):hover .social-card-icon {
    border-color: #e1306c;
    color: #e1306c;
    box-shadow: 0 0 12px rgba(225, 48, 108, 0.2);
  }

  /* Facebook Hover */
  .social-card:nth-child(4):hover {
    border-color: rgba(24, 119, 242, 0.3);
    box-shadow: 0 10px 15px -3px rgba(24, 119, 242, 0.08);
  }
  .social-card:nth-child(4):hover .social-card-icon {
    border-color: #1877f2;
    color: #1877f2;
    box-shadow: 0 0 12px rgba(24, 119, 242, 0.2);
  }

  /* Streaming Divider */
  .streaming-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 1.5rem 0 0.5rem 0;
    width: 100%;
  }

  .divider-line {
    flex-grow: 1;
    height: 1px;
    background-color: var(--border-color);
  }

  .streaming-title {
    font-family: var(--font-heading);
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-muted);
    white-space: nowrap;
  }

  /* Kick & Twitch specific styles */
  .kick-svg {
    width: 20px;
    height: 20px;
  }

  .social-card.kick-card:hover {
    border-color: rgba(83, 252, 24, 0.3);
    box-shadow: 0 10px 15px -3px rgba(83, 252, 24, 0.08);
  }
  .social-card.kick-card:hover .kick-icon-container {
    border-color: #53fc18;
    color: #53fc18;
    box-shadow: 0 0 12px rgba(83, 252, 24, 0.25);
  }

  .social-card.twitch-card:hover {
    border-color: rgba(145, 70, 255, 0.3);
    box-shadow: 0 10px 15px -3px rgba(145, 70, 255, 0.08);
  }
  .social-card.twitch-card:hover .twitch-icon-container {
    border-color: #a970ff;
    color: #a970ff;
    box-shadow: 0 0 12px rgba(145, 70, 255, 0.25);
  }

  .social-card.steam-card:hover {
    border-color: rgba(102, 192, 244, 0.3);
    box-shadow: 0 10px 15px -3px rgba(102, 192, 244, 0.08);
  }
  .social-card.steam-card:hover .steam-icon-container {
    border-color: #66c0f4;
    color: #66c0f4;
    box-shadow: 0 0 12px rgba(102, 192, 244, 0.25);
  }

  .social-card.xbox-card:hover {
    border-color: rgba(16, 124, 16, 0.3);
    box-shadow: 0 10px 15px -3px rgba(16, 124, 16, 0.08);
  }
  .social-card.xbox-card:hover .xbox-icon-container {
    border-color: #107c10;
    color: #107c10;
    box-shadow: 0 0 12px rgba(16, 124, 16, 0.25);
  }
</style>

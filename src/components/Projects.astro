---
import portfolioData from "../data/portfolio.json";

const { projects } = portfolioData;

const getTagColorClass = (tech: string) => {
  const t = tech.toLowerCase();
  if (t.includes('c#') || t.includes('.net')) return 'tag-net';
  if (t.includes('blazor')) return 'tag-blazor';
  if (t.includes('php') || t.includes('mysql')) return 'tag-php';
  if (t.includes('js') || t.includes('javascript')) return 'tag-js';
  if (t.includes('sql')) return 'tag-sql';
  if (t.includes('redes') || t.includes('mantenimiento') || t.includes('software')) return 'tag-infra';
  return 'tag-default';
};
---

<div class="panel-projects">
  <div class="projects-cv-list">
    {projects.map((project) => (
      <div class="project-cv-item" data-project-id={project.id}>
        <div class="project-cv-header">
          <div class="project-cv-title-group">
            <h4 class="project-cv-title">{project.title}</h4>
            <span class="project-cv-role">{project.role}</span>
          </div>
          <span class="project-cv-date">{project.period}</span>
        </div>
        <p class="project-cv-desc">{project.description}</p>
        
        <div class="project-cv-footer">
          <div class="project-cv-tags">
            {project.technologies.slice(0, 3).map((tech) => (
              <span class={`tech-tag ${getTagColorClass(tech)}`}>{tech}</span>
            ))}
            {project.technologies.length > 3 && (
              <span class="tech-tag tag-default">+{project.technologies.length - 3}</span>
            )}
          </div>
          <span class="btn-more">Ver detalles <i class="fas fa-arrow-right"></i></span>
        </div>
      </div>
    ))}
  </div>
</div>



<style>
  .panel-projects {
    display: flex;
    flex-direction: column;
  }

  .projects-cv-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .project-cv-item {
    background-color: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 12px;
    padding: 1.25rem;
    cursor: pointer;
    transition: all var(--transition-speed) cubic-bezier(0.4, 0, 0.2, 1);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
  }

  .project-cv-item:hover {
    border-color: var(--border-color-hover);
    background-color: var(--bg-hover);
    transform: translateY(-3px);
    box-shadow: 0 10px 20px -5px rgba(0, 0, 0, 0.2), 0 8px 8px -5px rgba(0, 0, 0, 0.1);
  }

  .project-cv-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1rem;
  }

  .project-cv-title-group {
    display: flex;
    flex-direction: column;
  }

  .project-cv-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .project-cv-role {
    font-size: 0.8rem;
    color: var(--accent-blue);
    font-weight: 600;
  }

  .project-cv-date {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 600;
    white-space: nowrap;
  }

  .project-cv-desc {
    font-size: 0.88rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .project-cv-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--border-color);
    padding-top: 0.75rem;
  }

  .project-cv-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tech-tag {
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* Tag styles */
  .tag-net { background: rgba(59, 130, 246, 0.1); color: var(--accent-blue); border: 1px solid rgba(59, 130, 246, 0.2); }
  .tag-blazor { background: rgba(139, 92, 246, 0.1); color: #c084fc; border: 1px solid rgba(139, 92, 246, 0.2); }
  .tag-php { background: rgba(79, 70, 229, 0.1); color: #818cf8; border: 1px solid rgba(79, 70, 229, 0.2); }
  .tag-js { background: rgba(234, 179, 8, 0.1); color: #facc15; border: 1px solid rgba(234, 179, 8, 0.2); }
  .tag-sql { background: rgba(16, 185, 129, 0.1); color: #34d399; border: 1px solid rgba(16, 185, 129, 0.2); }
  .tag-infra { background: rgba(20, 184, 166, 0.1); color: #2dd4bf; border: 1px solid rgba(20, 184, 166, 0.2); }
  .tag-default { background: rgba(148, 163, 184, 0.1); color: #cbd5e1; border: 1px solid rgba(148, 163, 184, 0.2); }

  .btn-more {
    font-size: 0.82rem;
    font-weight: 700;
    color: var(--accent-blue);
    display: flex;
    align-items: center;
    gap: 0.3rem;
  }

  .btn-more i {
    transition: transform var(--transition-speed) ease;
  }

  .project-cv-item:hover .btn-more i {
    transform: translateX(3px);
  }
</style>

<script>
  const setupModals = () => {
    const items = document.querySelectorAll('.project-cv-item');
    const closeBtns = document.querySelectorAll('.modal-close-btn, .btn-close-modal');
    const overlays = document.querySelectorAll('.modal-overlay');

    items.forEach(item => {
      item.addEventListener('click', () => {
        const id = item.getAttribute('data-project-id');
        const modal = document.getElementById(`modal-${id}`);
        if (modal) {
          modal.classList.add('open');
          document.body.style.overflow = 'hidden';
        }
      });
    });

    const close = (modal: HTMLElement) => {
      modal.classList.remove('open');
      document.body.style.overflow = '';
    };

    closeBtns.forEach(btn => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        const targetId = btn.getAttribute('data-close-target');
        const modal = document.getElementById(targetId || '');
        if (modal) close(modal);
      });
    });

    overlays.forEach(overlay => {
      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) close(overlay as HTMLElement);
      });
    });
  };

  setupModals();
  document.addEventListener('astro:after-swap', setupModals);
</script>

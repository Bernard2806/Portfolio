---
// Education.astro
---

<div class="panel-education">
  <div class="edu-timeline">
    <!-- University -->
    <div class="edu-item">
      <div class="edu-icon">
        <i class="fas fa-university"></i>
      </div>
      <div class="edu-details">
        <h4 class="edu-title">Universidad Nacional de Luján (UNLu)</h4>
        <p class="edu-degree">Licenciatura en Sistemas</p>
        <span class="edu-period">Cursando (Ingreso 2026) • Duración estimada: 5 años</span>
      </div>
    </div>

    <!-- Secondary School -->
    <div class="edu-item">
      <div class="edu-icon">
        <i class="fas fa-school"></i>
      </div>
      <div class="edu-details">
        <h4 class="edu-title">Escuela Secundaria Técnica N°1 "Mariano Moreno"</h4>
        <p class="edu-degree">Técnico en Informática</p>
        <span class="edu-period">Egresado en 2024</span>
      </div>
    </div>
  </div>
</div>

<style>
  .panel-education {
    display: flex;
    flex-direction: column;
  }

  .edu-timeline {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    position: relative;
  }

  /* Vertical line connecting the timeline items */
  .edu-timeline::before {
    content: "";
    position: absolute;
    left: 19px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background-color: var(--border-color);
    z-index: 0;
  }

  .edu-item {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    position: relative;
    z-index: 1;
  }

  .edu-icon {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background-color: var(--bg-card);
    border: 2px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.95rem;
    color: var(--accent-blue);
    flex-shrink: 0;
    transition: all var(--transition-speed) ease;
  }

  .edu-item:hover .edu-icon {
    border-color: var(--accent-blue);
    color: var(--text-primary);
    background-color: var(--bg-hover);
    transform: scale(1.1);
    box-shadow: 0 0 10px rgba(34, 197, 94, 0.2);
  }

  .edu-details {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .edu-title {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .edu-degree {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--accent-teal);
  }

  .edu-period {
    font-size: 0.8rem;
    color: var(--text-muted);
  }
</style>

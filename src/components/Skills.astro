---
import portfolioData from "../data/portfolio.json";

const { webDevelopment, otherTechnologies } = portfolioData.skills;
---

<div class="panel-skills">
  <!-- Web Development -->
  <div class="skills-block">
    <h4 class="skills-block-title"><i class="fas fa-laptop-code"></i> Desarrollo Web</h4>
    <div class="skills-cv-list">
      {webDevelopment.map((skill) => (
        <div class="skill-cv-row">
          <div class="skill-cv-label">
            <span class="skill-cv-name"><i class={skill.icon}></i> {skill.name}</span>
            <span class="skill-cv-val">{skill.level}%</span>
          </div>
          <div class="skill-cv-track">
            <div class="skill-cv-fill" style={`width: ${skill.level}%`}></div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Other Technologies -->
  <div class="skills-block">
    <h4 class="skills-block-title"><i class="fas fa-gears"></i> Otras Tecnologías</h4>
    <div class="skills-cv-list">
      {otherTechnologies.map((skill) => (
        <div class="skill-cv-row">
          <div class="skill-cv-label">
            <span class="skill-cv-name"><i class={skill.icon}></i> {skill.name}</span>
            <span class="skill-cv-val">{skill.level}%</span>
          </div>
          <div class="skill-cv-track">
            <div class="skill-cv-fill" style={`width: ${skill.level}%`}></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .panel-skills {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .skills-block {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .skills-block-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--text-primary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 0.5rem;
  }

  .skills-block-title i {
    color: var(--accent-blue);
  }

  .skills-cv-list {
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  .skill-cv-row {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .skill-cv-label {
    display: flex;
    justify-content: space-between;
    font-size: 0.88rem;
    font-weight: 600;
  }

  .skill-cv-name {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .skill-cv-name i {
    width: 20px;
    color: var(--text-muted);
    text-align: center;
  }

  .skill-cv-val {
    color: var(--text-muted);
  }

  .skill-cv-track {
    width: 100%;
    height: 6px;
    background-color: var(--bg-hover);
    border-radius: 3px;
    overflow: hidden;
    border: 1px solid var(--border-color);
  }

  .skill-cv-fill {
    height: 100%;
    background-color: var(--text-primary); /* Formal white/black depending on theme */
    border-radius: 3px;
    transition: width 1s ease-out;
  }

  /* Specific color accent for active/hover states or theme toggles */
  [data-theme="light"] .skill-cv-fill {
    background-color: var(--accent-blue);
  }
</style>

---
// Experience.astro
---

<div class="panel-experience">
  <div class="exp-timeline">
    <!-- IPNext Telecomunicaciones -->
    <div class="exp-item">
      <div class="exp-icon">
        <i class="fas fa-network-wired"></i>
      </div>
      <div class="exp-details">
        <h4 class="exp-title">Técnico de Instalación</h4>
        <p class="exp-company">IPNext Telecomunicaciones • Autónomo</p>
        <span class="exp-period">Jun 2025 - Jul 2025</span>
        <p class="exp-desc">Instalación y configuración de redes informáticas, cableado estructurado y sistemas de cámaras IP.</p>
      </div>
    </div>

    <!-- Bomberos Voluntarios de Chivilcoy -->
    <div class="exp-item">
      <div class="exp-icon">
        <i class="fas fa-fire-extinguisher"></i>
      </div>
      <div class="exp-details">
        <h4 class="exp-title">Desarrollador Web (Pasantía)</h4>
        <p class="exp-company">Bomberos Voluntarios de Chivilcoy • Prácticas</p>
        <span class="exp-period">Jun 2024 - Sep 2024</span>
        <p class="exp-desc">Desarrollo y reestructuración del sistema de gestión del cuartel, implementando mejoras y nuevas funcionalidades con ASP.NET y .NET Framework.</p>
      </div>
    </div>
  </div>
</div>

<style>
  .panel-experience {
    display: flex;
    flex-direction: column;
  }

  .exp-timeline {
    display: flex;
    flex-direction: column;
    gap: 1.75rem;
    position: relative;
  }

  /* Vertical line connecting the timeline items */
  .exp-timeline::before {
    content: "";
    position: absolute;
    left: 19px;
    top: 8px;
    bottom: 8px;
    width: 2px;
    background-color: var(--border-color);
    z-index: 0;
  }

  .exp-item {
    display: flex;
    align-items: flex-start;
    gap: 1.25rem;
    position: relative;
    z-index: 1;
  }

  .exp-icon {
    width: 38px;
    height: 38px;
    border-radius: 50%;
    background-color: var(--bg-card);
    border: 2px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.95rem;
    color: var(--accent-blue);
    flex-shrink: 0;
    transition: all var(--transition-speed) ease;
  }

  .exp-item:hover .exp-icon {
    border-color: var(--accent-blue);
    color: var(--text-primary);
    background-color: var(--bg-hover);
    transform: scale(1.1);
    box-shadow: 0 0 10px rgba(34, 197, 94, 0.2);
  }

  .exp-details {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .exp-title {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .exp-company {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--accent-teal);
  }

  .exp-period {
    font-size: 0.8rem;
    color: var(--text-muted);
  }

  .exp-desc {
    font-size: 0.84rem;
    color: var(--text-secondary);
    line-height: 1.4;
    margin-top: 0.25rem;
  }
</style>

---
import portfolioData from "../data/portfolio.json";

const { projects } = portfolioData;

const getTagColorClass = (tech: string) => {
  const t = tech.toLowerCase();
  if (t.includes('c#') || t.includes('.net')) return 'tag-net';
  if (t.includes('blazor')) return 'tag-blazor';
  if (t.includes('php') || t.includes('mysql')) return 'tag-php';
  if (t.includes('js') || t.includes('javascript')) return 'tag-js';
  if (t.includes('sql')) return 'tag-sql';
  if (t.includes('redes') || t.includes('mantenimiento') || t.includes('software')) return 'tag-infra';
  return 'tag-default';
};
---

<!-- Render modals for each project -->
{projects.map((project) => (
  <div class="modal-overlay" id={`modal-${project.id}`}>
    <div class="modal-container">
      <div class="modal-header">
        <h3 class="modal-title">{project.title}</h3>
        <button class="modal-close-btn" data-close-target={`modal-${project.id}`} aria-label="Cerrar">
          <i class="fas fa-times"></i>
        </button>
      </div>

      <div class="modal-body">
        <div class="modal-meta-row">
          <div class="modal-meta-item">
            <strong>Rol:</strong> {project.role}
          </div>
          <div class="modal-meta-item">
            <strong>Período:</strong> {project.period}
          </div>
        </div>

        <div class="modal-content-section">
          <h4 class="modal-desc-heading">Descripción del Proyecto</h4>
          <p class="modal-desc">{project.longDescription || project.description}</p>
        </div>

        {project.features && project.features.length > 0 && (
          <div class="modal-content-section">
            <h4 class="modal-desc-heading">Características Destacadas</h4>
            <ul class="modal-list">
              {project.features.map((feature) => (
                <li>
                  <i class="fas fa-circle-check"></i>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>
          </div>
        )}

        <div class="modal-content-section">
          <h4 class="modal-desc-heading">Tecnologías</h4>
          <div class="project-cv-tags">
            {project.technologies.map((tech) => (
              <span class={`tech-tag ${getTagColorClass(tech)}`}>{tech}</span>
            ))}
          </div>
        </div>
      </div>

      <div class="modal-footer">
        <button class="btn btn-secondary btn-close-modal" data-close-target={`modal-${project.id}`}>Cerrar</button>
        {project.links.github && project.links.github !== "#" && (
          <a href={project.links.github} target="_blank" rel="noopener noreferrer" class="btn btn-secondary">
            <i class="fab fa-github"></i> Código
          </a>
        )}
        {project.links.demo && project.links.demo !== "#" && (
          <a href={project.links.demo} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
            <i class="fas fa-external-link-alt"></i> Demo
          </a>
        )}
      </div>
    </div>
  </div>
))}

<style>
  .project-cv-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tech-tag {
    font-size: 0.65rem;
    font-weight: 600;
    padding: 0.2rem 0.4rem;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  /* Tag styles */
  .tag-net { background: rgba(59, 130, 246, 0.1); color: var(--accent-blue); border: 1px solid rgba(59, 130, 246, 0.2); }
  .tag-blazor { background: rgba(139, 92, 246, 0.1); color: #c084fc; border: 1px solid rgba(139, 92, 246, 0.2); }
  .tag-php { background: rgba(79, 70, 229, 0.1); color: #818cf8; border: 1px solid rgba(79, 70, 229, 0.2); }
  .tag-js { background: rgba(234, 179, 8, 0.1); color: #facc15; border: 1px solid rgba(234, 179, 8, 0.2); }
  .tag-sql { background: rgba(16, 185, 129, 0.1); color: #34d399; border: 1px solid rgba(16, 185, 129, 0.2); }
  .tag-infra { background: rgba(20, 184, 166, 0.1); color: #2dd4bf; border: 1px solid rgba(20, 184, 166, 0.2); }
  .tag-default { background: rgba(148, 163, 184, 0.1); color: #cbd5e1; border: 1px solid rgba(148, 163, 184, 0.2); }
</style>

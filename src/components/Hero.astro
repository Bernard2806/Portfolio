---
import portfolioData from "../data/portfolio.json";
import ThemeToggle from "./ThemeToggle.astro";

const { name, lastName, title, location, email, github, linkedin, avatar } = portfolioData.personalInfo;
---

<div class="card-banner">
  <!-- Theme switcher positioned in the top-right of the profile banner -->
  <div class="banner-toggle-position">
    <ThemeToggle />
  </div>
</div>

<div class="avatar-container">
  <img src={avatar} alt={`${name} ${lastName}`} class="profile-avatar-overlay" />
</div>

<div class="profile-info">
  <h1 class="profile-name">{name} {lastName}</h1>
  <p class="profile-title">{title}</p>
  <div class="profile-meta">
    <span><i class="fas fa-map-marker-alt"></i> {location}</span>
  </div>
</div>

<!-- Social Links Row -->
<div class="profile-socials">
  <a href={github} target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="GitHub">
    <i class="fab fa-github"></i>
  </a>
  <a href={linkedin} target="_blank" rel="noopener noreferrer" class="social-icon" aria-label="LinkedIn">
    <i class="fab fa-linkedin-in"></i>
  </a>
  <a href={`mailto:${email}`} class="social-icon" aria-label="Email">
    <i class="fas fa-envelope"></i>
  </a>
</div>

<!-- Linktree Style Tab Buttons Stack -->
<div class="linktree-menu">
  <button class="linktree-btn active" data-tab="about">
    <span class="btn-icon"><i class="fas fa-user-tie"></i></span>
    <span class="btn-text">Sobre Mí</span>
    <span class="btn-chevron"><i class="fas fa-chevron-right"></i></span>
  </button>

  <button class="linktree-btn" data-tab="skills">
    <span class="btn-icon"><i class="fas fa-laptop-code"></i></span>
    <span class="btn-text">Habilidades</span>
    <span class="btn-chevron"><i class="fas fa-chevron-right"></i></span>
  </button>

  <button class="linktree-btn" data-tab="projects">
    <span class="btn-icon"><i class="fas fa-briefcase"></i></span>
    <span class="btn-text">Proyectos Destacados</span>
    <span class="btn-chevron"><i class="fas fa-chevron-right"></i></span>
  </button>

  <button class="linktree-btn" data-tab="products">
    <span class="btn-icon"><i class="fas fa-shopping-bag"></i></span>
    <span class="btn-text">Software & SaaS en Venta</span>
    <span class="btn-chevron"><i class="fas fa-chevron-right"></i></span>
  </button>

  <button class="linktree-btn" data-tab="contact">
    <span class="btn-icon"><i class="fas fa-envelope"></i></span>
    <span class="btn-text">Enviar Mensaje</span>
    <span class="btn-chevron"><i class="fas fa-chevron-right"></i></span>
  </button>
  
  <button class="linktree-btn" data-tab="share">
    <span class="btn-icon"><i class="fas fa-qrcode"></i></span>
    <span class="btn-text">Compartir Portafolio</span>
    <span class="btn-chevron"><i class="fas fa-chevron-right"></i></span>
  </button>
</div>

<style>
  .banner-toggle-position {
    position: absolute;
    top: 1rem;
    right: 1rem;
    z-index: 20;
  }
</style>

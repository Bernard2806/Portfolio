<div class="canvas-container">
  <canvas id="bubble-bg-canvas"></canvas>
</div>

<style>
  .canvas-container {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: -1;
    pointer-events: none;
    overflow: hidden;
  }
  
  #bubble-bg-canvas {
    display: block;
    width: 100%;
    height: 100%;
    opacity: 0.85;
  }
</style>

<script>
  interface Bubble {
    x: number;
    y: number;
    radius: number;
    speed: number;
    angle: number;
    angleSpeed: number;
    drift: number;
  }

  const initBubbleBackground = () => {
    const canvas = document.getElementById('bubble-bg-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let width = (canvas.width = window.innerWidth);
    let height = (canvas.height = window.innerHeight);

    // Number of bubbles depends on screen size (for performance)
    let maxBubbles = width < 768 ? 20 : 45;
    let bubbles: Bubble[] = [];

    // Colors derived dynamically from CSS variables
    let bubbleColorRGB = '117, 144, 128'; // Default fallback (sage green: #759080)

    // Offscreen canvas for pre-rendering bubble gradient
    const offscreenCanvas = document.createElement('canvas');
    const oCtx = offscreenCanvas.getContext('2d');
    
    const preRenderBubble = () => {
      offscreenCanvas.width = 64;
      offscreenCanvas.height = 64;
      if (!oCtx) return;
      oCtx.clearRect(0, 0, 64, 64);
      
      const grad = oCtx.createRadialGradient(32, 32, 0, 32, 32, 32);
      grad.addColorStop(0, `rgba(${bubbleColorRGB}, 0.18)`);
      grad.addColorStop(0.5, `rgba(${bubbleColorRGB}, 0.08)`);
      grad.addColorStop(1, `rgba(${bubbleColorRGB}, 0)`);
      
      oCtx.fillStyle = grad;
      oCtx.beginPath();
      oCtx.arc(32, 32, 32, 0, Math.PI * 2);
      oCtx.fill();
    };

    const updateColors = () => {
      const tempDiv = document.createElement('div');
      tempDiv.style.color = 'var(--text-muted)';
      document.body.appendChild(tempDiv);
      const style = window.getComputedStyle(tempDiv).color;
      document.body.removeChild(tempDiv);
      
      // Parse rgb(...) or rgba(...) format
      const match = style.match(/\d+/g);
      if (match && match.length >= 3) {
        bubbleColorRGB = `${match[0]}, ${match[1]}, ${match[2]}`;
      }
    };

    const createBubble = (isInit = false): Bubble => {
      const radius = Math.random() * 8 + 3; // 3px to 11px
      return {
        x: Math.random() * width,
        y: isInit ? Math.random() * height : height + radius + Math.random() * 100,
        radius,
        speed: Math.random() * 0.4 + 0.2, // 0.2 to 0.6 speed
        angle: Math.random() * Math.PI * 2,
        angleSpeed: Math.random() * 0.02 - 0.01,
        drift: Math.random() * 0.4 + 0.1
      };
    };

    const initBubbles = () => {
      bubbles = [];
      for (let i = 0; i < maxBubbles; i++) {
        bubbles.push(createBubble(true));
      }
    };

    const draw = () => {
      ctx.clearRect(0, 0, width, height);

      bubbles.forEach((bubble) => {
        // Draw using pre-rendered canvas (diameter is bubble.radius * 4 because bubble.radius * 2 is the actual radius)
        const diameter = bubble.radius * 4;
        ctx.drawImage(
          offscreenCanvas,
          bubble.x - diameter / 2,
          bubble.y - diameter / 2,
          diameter,
          diameter
        );

        // Update positions
        bubble.y -= bubble.speed;
        bubble.angle += bubble.angleSpeed;
        bubble.x += Math.sin(bubble.angle) * bubble.drift;

        // Reset if it goes off screen top
        if (bubble.y < -bubble.radius * 2) {
          Object.assign(bubble, createBubble(false));
        }

        // Keep horizontal position in bounds
        if (bubble.x < -bubble.radius * 2) bubble.x = width + bubble.radius * 2;
        if (bubble.x > width + bubble.radius * 2) bubble.x = -bubble.radius * 2;
      });
    };

    let animationFrameId: number;
    const tick = () => {
      draw();
      animationFrameId = requestAnimationFrame(tick);
    };

    const handleResize = () => {
      width = canvas.width = window.innerWidth;
      height = canvas.height = window.innerHeight;
      maxBubbles = width < 768 ? 20 : 45;
      initBubbles();
    };

    // Listen for theme mutations to regenerate offscreen bubble color
    const themeObserver = new MutationObserver((mutations) => {
      mutations.forEach((mutation) => {
        if (mutation.attributeName === 'data-theme') {
          updateColors();
          preRenderBubble();
        }
      });
    });
    themeObserver.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });

    // Start everything
    updateColors();
    preRenderBubble();
    initBubbles();
    tick();

    window.addEventListener('resize', handleResize);

    // Cleanup function
    return () => {
      cancelAnimationFrame(animationFrameId);
      themeObserver.disconnect();
      window.removeEventListener('resize', handleResize);
    };
  };

  let cleanup: (() => void) | undefined;

  const runBg = () => {
    if (cleanup) cleanup();
    cleanup = initBubbleBackground();
  };

  // Run on initial page load
  runBg();
  
  // Re-run on Astro swaps
  document.addEventListener('astro:after-swap', runBg);
</script>
